#!/usr/bin/env sh
# vim: set ft=bash ts=8 sts=8 sw=8 colorcolumn=120:
#
# Pflogger: simple shell based logger.
#
# Development note:
#       This file has exactly (262) lines which is (Six) lines over the limit.


unset DARK_GREY DARK_BLUE LIGHT_BLUE WHITE YELLOW GREEN RED RESET

if [  -t 1 ]
then
        DARK_GREY='\033[90m'
        DARK_BLUE='\033[34m'
        LIGHT_BLUE='\033[96m'
        WHITE='\033[97m'
        YELLOW='\033[33m'
        GREEN='\033[32m'
        RED='\033[31m'
        RESET='\033[0m'
fi

log_level_value ()
{
        case "$1" in
                very_verbose|VERY_VERBOSE)      echo 1 ;;
                verbose|VERBOSE)                echo 2 ;;
                debug|DEBUG|blue)               echo 3 ;;
                info|INFO|white)                echo 4 ;;
                success|SUCCESS|green)          echo 5 ;;
                warning|WARNING|yellow)         echo 6 ;;
                error|ERROR|red)                echo 7 ;;
                none|NONE)                      echo 100 ;;
                *)                              return 1 ;;
        esac
}

exists ()
{
        if [ -z "$1" ]
        then
                pflogger error "Missing argument"
                return 1 
        fi
}

display_message ()
{
	level=$1
	message=$2
	global_log_level=${PFLOG_LEVEL:-"DEBUG"}

	exists "$level" || return 1
	exists "$message" || return 1

        current=$(log_level_value "$global_log_level")
        target=$(log_level_value "$level")

        if [ -z "$current" ]
        then
                fallback="DEBUG"
                printf '%b\n' "${RED}========================================${RESET}" >&2
                printf '%b\n' "${RED} Invalid PFLOG_LEVEL: '$global_log_level'${RESET}" >&2
                printf '%b\n' "${RED} Falling back to $fallback logging${RESET}" >&2
                printf '%b\n' "${RED}========================================${RESET}" >&2

                PFLOG_LEVEL="$fallback"
                current=$(log_level_value "$PFLOG_LEVEL")
        fi

        if [ "$target" -ge "$current" ]
        then
                printf '%b\n' "$message"
                safe_speak "$message"
        fi
}

speak() {
        message="$1"
        if [ -f "$PFREADY" ] && [ -p "$PFSPEAK" ]
        then
                printf '%s' "$message" > "$PFSPEAK" &
        fi
}

safe_speak () {
        message="$1"
        clean_message=$(printf '%b' "$message" | sed -E 's/\x1B\[[0-9;]*[[:alpha:]]//g')
        speak "$clean_message"
}

show_pflogger ()
{
	pflogger green		"Current log level: ${PFLOG_LEVEL:-"DEBUG"}"
        pflogger green          "Showing messages at these log levels"
	pflogger hr green
	pflogger very_verbose	"pflogger very_verbose  \"[message]\""
	pflogger verbose	"pflogger verbose       \"[message]\""
	pflogger debug		"pflogger debug         \"[message]\""
	pflogger info		"pflogger info          \"[message]\""
	pflogger success	"pflogger success       \"[message]\""
	pflogger warning	"pflogger warning       \"[message]\"" 
	pflogger error		"pflogger error         \"[message]\""
	pflogger blue		"pflogger blue          \"[message]\""
	pflogger green		"pflogger green         \"[message]\""
	pflogger yellow		"pflogger yellow        \"[message]\""
	pflogger red		"pflogger red           \"[message]\""
        printf '%b\n' "${DARK_GREY}pflogger ${LIGHT_BLUE}hr ${WHITE}[white|green|yellow|red] ${RESET}\n" >&2
        pflogger hr blue 
        pflogger hr white
        pflogger hr green
        pflogger hr yellow
        pflogger hr red

}

pflogger_help ()
{
	/bin/cat <<EOF
	Usage:
		pflogger [log_level] [message]

	Environment:
		LOG_LEVEL=<level>
			Suppress messages below the specified log level.
                PFREADY=<path>
                        Path to the PfSpeak ready file.
                PFSPEAK=<path>
                        Path to the PfSpeak daemon pipe.

	Log levels:
		vverbose: Very verbose
		verbose: Verbose
		debug: Debug
		info: Info
		success: Success
		warning: Warning
		error: Error

	Color commands:
		blue: Print message in green
		white: Print message in green
		green: Print message in green
		yellow: Print message in yellow
		red: Print message in red

	Formatting commands:
                hr [blue|white|green|yellow|red]: Print a horizontal dashes

	Additional options:
		show: Display examples of pflogger formatting 
		help: Display this help message
EOF
}

hr ()
{
        color="$1"
        line="---------"
        case $color in
                blue)
                        echo "${LIGHT_BLUE}${line}${RESET}"
                        ;;
                white)
                        echo "${WHITE}${line}${RESET}"
                        ;;
                green)
                        echo "${GREEN}${line}${RESET}"
                        ;;
                yellow)
                        echo "${YELLOW}${line}${RESET}"
                        ;;
                red)
                        echo "${RED}${line}${RESET}"
                        ;;
                '')
                        echo "${WHITE}${line}${RESET}"
                        ;;
        esac
}

pflogger ()
{
	level=$1
	message=$2
        formatted_message=""

	case $level in
		very_verbose)
			formatted_message="${DARK_GREY}TRIVIAL: ${message}${RESET}"
			;;
		verbose)
			formatted_message="${DARK_BLUE} VERBOSE: ${message}${RESET}"
			;;
		debug)
			formatted_message="${LIGHT_BLUE}   DEBUG: ${message}${RESET}"
			;;
		info)
			formatted_message="${WHITE}    INFO: ${message}${RESET}"
			;;
		success)
			formatted_message="${GREEN} SUCCESS: ${message}${RESET}"
			;;
		warning)
			formatted_message="${YELLOW} WARNING: ${message}${RESET}"
			;;
		error)
			formatted_message="${RED}   ERROR: ${message}${RESET}"
			;;
		blue)
			formatted_message="${LIGHT_BLUE}          ${message}${RESET}"
			;;
		white)
			formatted_message="${WHITE}          ${message}${RESET}"
			;;
		green)
			formatted_message="${GREEN}          ${message}${RESET}"
			;;
		yellow)
			formatted_message="${YELLOW}          ${message}${RESET}"
			;;
		red)
			formatted_message="${RED}          ${message}${RESET}"
			;;
		hr)
                        level="$message"
                        formatted_message=$(hr "$level")
			;;

		show)
			show_pflogger
			return 0
			;;
		help)
			pflogger_help
			return 0
			;;
                skip)
                        speak "\$SKIP"
                        echo "skipping"
			return 0
                        ;;
                clear)
                        speak "\$BREAK"
			return 0
                        ;;
		"")
			pflogger error "No log arguments provided"
			pflogger red "Use 'pflogger help' for more information"
			return 1
			;;
		*)
			formatted_message="${WHITE}          ${level} ${message}${RESET}"
                        level="none"
			;;
	esac

        display_message "$level" "$formatted_message" || return 1
}

pflogger "$@"
